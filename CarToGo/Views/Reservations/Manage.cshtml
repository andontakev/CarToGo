@model List<CarToGo.Models.Reservation>

@{
    ViewData["Title"] = "Manage Reservations";
}

<h2>Manage Reservations</h2>

<table class="table table-striped mt-3">
    <thead>
        <tr>
            <th>User</th>
            <th>Car</th>
            <th>Period</th>
            <th>Total Price</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td class="text-white">@r.User.Email</td>
                <td class="text-white">@r.Car.Brand @r.Car.Model</td>
                <td class="text-white">@r.StartDate.ToShortDateString() - @r.EndDate.ToShortDateString()</td>
                <td class="text-white">@r.TotalPrice</td>
                <td class="text-white">@r.Status</td>
                <td>
                    @if (r.Status == "Pending")
                    {
                        <a asp-action="Approve" asp-route-id="@r.Id" class="btn btn-success btn-sm">Approve</a>
                        <a asp-action="Reject" asp-route-id="@r.Id" class="btn btn-danger btn-sm">Reject</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

