@model List<CarToGo.Models.Reservation>

@{
    ViewData["Title"] = "Manage Reservations";
}

<h2>Manage Reservations</h2>

<table class="table table-striped mt-3 text-light">
    <thead>
        <tr>
            <th class="text-light">User</th>
            <th class="text-light">Car</th>
            <th class="text-light">Period</th>
            <th class="text-light">Total Price</th>
            <th class="text-light">Status</th>
            <th class="text-light">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var r in Model)
        {
            <tr class="text-light">
                <td class="text-light">@r.User.Email</td>
                <td class="text-light">@r.Car.Brand @r.Car.Model</td>
                <td class="text-light">@r.StartDate.ToShortDateString() - @r.EndDate.ToShortDateString()</td>
                <td class="text-light">@r.TotalPrice</td>
                <td class="text-light">@r.Status</td>
                <td>
                    @if (r.Status == "Pending")
                    {
                        <a asp-action="Approve" asp-route-id="@r.Id" class="btn btn-success btn-sm">Approve</a>
                        <a asp-action="Reject" asp-route-id="@r.Id" class="btn btn-danger btn-sm">Reject</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

