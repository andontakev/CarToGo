@{
    ViewData["Title"] = "New Reservation";
}

<h2>New Reservation</h2>

<form asp-action="AvailableCars" method="post" class="col-6">

    <div class="form-group">
        <label>Start Date</label>
        <input type="date" name="startDate" class="form-control" required min="@DateTime.Today.ToString("yyyy-MM-dd")" />
    </div>

    <div class="form-group mt-3">
        <label>End Date</label>
        <input type="date" name="endDate" class="form-control" required min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
    </div>

    <button type="submit" class="btn btn-primary mt-3">Search</button>

</form>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mt-3">@TempData["Error"]</div>
}

