@using CarToGo.ViewModel;
@model List<AvailableCarViewModel>

@{
    ViewData["Title"] = "Available Cars";
}

<h2>Available Cars</h2>

@if (!Model.Any())
{
    <div class="alert alert-warning">No cars available for the selected period.</div>
}
else
{
    <table class="table table-striped mt-3">
        <thead>
            <tr>
                <th>Car</th>
                <th>Year</th>
                <th>Seats</th>
                <th>Price/Day</th>
                <th>Total Price</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var car in Model)
            {
                <tr class="text-white">
                    <td class="text-white">@car.Brand @car.Model</td>
                    <td class="text-white">@car.Year</td>
                    <td class="text-white">@car.Seats</td>
                    <td class="text-white">@car.PricePerDay</td>
                    <td class="text-white">@car.TotalPrice</td>
                    <td>
                        <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.CarId" asp-route-returnUrl="AvailableCars" class="btn btn-info">
                            Details
                        </a>

                        <form asp-action="MakeReservation" method="post" style="display:inline;">
                            <input type="hidden" name="carId" value="@car.CarId" />
                            <input type="hidden" name="startDate" value="@car.StartDate" />
                            <input type="hidden" name="endDate" value="@car.EndDate" />
                            <button type="submit" class="btn btn-success">Make Reservation</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

