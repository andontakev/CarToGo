@using Microsoft.AspNetCore.Identity
@model IdentityRole

<h3>You are about to delete the role "@Model.Name"</h3>
<h6>This action can't be undone</h6>

<form method="post" asp-action="DeleteRole" asp-route-id="@Model.Id" class="mt-3">
    <button type="submit" class="btn btn-danger">Delete</button>
    <div>
        <a asp-action="ListAllRoles" class="btn btn-warning">Cancel</a>
    </div>
</form>