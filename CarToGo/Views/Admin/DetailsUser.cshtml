@model DefaultUser

<h2>User Details</h2>

<div class="card mt-3">
    <div class="card-body">

        <h4 class="card-title">@Model.FirstName @Model.LastName</h4>
        <hr />

        <p><strong>First Name:</strong> @Model.FirstName</p>
        <p><strong>Last Name:</strong> @Model.LastName</p>
        <p><strong>Email:</strong> @Model.Email</p>
        <p><strong>EGN:</strong> @Model.EGN</p>
        <p><strong>Phone Number:</strong> @Model.PhoneNumber</p>
        <p><strong>Username:</strong> @Model.UserName</p>

    </div>
</div>

<div class="mt-3">
    <a asp-action="EditUser" asp-controller="Admin" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="ListAllUsers" asp-controller="Admin" class="btn btn-secondary">Back</a>
</div>

