@page
@model MyReservationsModel
@using CarToGo.Models

@{
    ViewData["Title"] = "My Reservations";
    ViewData["ActivePage"] = ManageNavPages.MyReservations;
}

<h3>@ViewData["Title"]</h3>

@if (!Model.Reservations.Any())
{
    <div class="alert alert-info">You have no reservations yet.</div>
}
else
{
    <table class="table table-bordered mt-3">
        <thead>
            <tr>
                <th>Car</th>
                <th>Period</th>
                <th>Total Price</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model.Reservations)
            {
                <tr>
                    <td>@r.Car.Brand @r.Car.Model</td>
                    <td>@r.StartDate.ToShortDateString() - @r.EndDate.ToShortDateString()</td>
                    <td>@string.Format("{0:0.00} €", r.TotalPrice)</td>
                    <td>
                        @if (r.Status == "Pending")
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                        else if (r.Status == "Approved" || r.Status == "Confirmed")
                        {
                            <span class="badge bg-success">Approved</span>
                        }
                        else if (r.Status == "Canceled")
                        {
                            <span class="badge bg-secondary">Canceled</span>
                        }
                        else if (r.Status == "Rejected")
                        {
                            <span class="badge bg-danger">Rejected</span>
                        }
                    </td>
                    <td>
                        @if (r.Status == "Pending")
                        {
                            <form method="post" asp-page-handler="Cancel" asp-route-id="@r.Id" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to cancel this reservation?')">Cancel</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
