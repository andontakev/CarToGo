@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<section class="auth-page">
    <div class="container px-4">
        <div class="row justify-content-center">
            <div class="col-xl-8">
                <div class="content-panel reveal">
                    <div class="auth-panel-header">
                        <h1>Welcome back</h1>
                        <p>Sign in to access your reservations and manage your profile securely.</p>
                    </div>
                    <div class="row gx-4 gy-4">
                        <div class="col-md-6">
                            <div class="auth-panel">
                                <form id="account" method="post">
                                    <h2>Account login</h2>
                                    <p class="text-muted">Enter your email and password to continue.</p>
                                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                                    <div class="form-floating mb-3">
                                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                                        <label asp-for="Input.Email">Email</label>
                                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                                    </div>
                                    <div class="form-floating mb-3">
                                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Password" />
                                        <label asp-for="Input.Password">Password</label>
                                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                                    </div>
                                    <div class="form-check mb-3">
                                        <input class="form-check-input" asp-for="Input.RememberMe" />
                                        <label class="form-check-label" asp-for="Input.RememberMe">@Html.DisplayNameFor(m => m.Input.RememberMe)</label>
                                    </div>
                                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Log in</button>
                                    <div class="mt-3">
                                        <p><a id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a></p>
                                        <p><a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create a new account</a></p>
                                        <p><a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend email confirmation</a></p>
                                    </div>
                                </form>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="auth-panel-secondary">
                                <h2>Secure access</h2>
                                <p>CarToGo keeps your login safe with secure authentication and support for external providers.</p>
                                @{
                                    if ((Model.ExternalLogins?.Count ?? 0) == 0)
                                    {
                                        <p class="text-muted">No external login providers are configured at the moment.</p>
                                    }
                                    else
                                    {
                                        <div class="d-grid gap-2">
                                            @foreach (var provider in Model.ExternalLogins!)
                                            {
                                                <form id="external-account-@provider.Name" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                                                    <button type="submit" class="btn btn-outline-light btn-lg" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">Continue with @provider.DisplayName</button>
                                                </form>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
